# ══════════════════════════════════════════════════════════════════════════════
# ALPHABETA — Production Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
#
# INSTRUCTIONS:
#   cp .env.production.example .env.production
#   nano .env.production       # fill in every value marked <CHANGE ME>
#   chmod 600 .env.production  # restrict file permissions
#
# To start production stack:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_NAME=alphabeta_prod
DATABASE_USERNAME=alphabeta_user
DATABASE_PASSWORD=<CHANGE ME — use: openssl rand -base64 32>

# ── Strapi Secrets ────────────────────────────────────────────────────────────
# Generate each with: openssl rand -base64 32
# APP_KEYS requires 4 comma-separated base64 values:
#   e.g.  $(openssl rand -base64 32),$(openssl rand -base64 32),$(openssl rand -base64 32),$(openssl rand -base64 32)
APP_KEYS=<key1>,<key2>,<key3>,<key4>
API_TOKEN_SALT=<CHANGE ME — openssl rand -base64 32>
ADMIN_JWT_SECRET=<CHANGE ME — openssl rand -base64 32>
JWT_SECRET=<CHANGE ME — openssl rand -base64 32>
TRANSFER_TOKEN_SALT=<CHANGE ME — openssl rand -base64 32>

# ── Email (Brevo SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.brevo.com
SMTP_PORT=587
SMTP_USER=<CHANGE ME — your Brevo login email>
SMTP_PASS=<CHANGE ME — your Brevo SMTP key>
EMAIL_FROM=noreply@alphabeta.ly
EMAIL_REPLY_TO=info@alphabeta.ly

# ── SSL / Let's Encrypt ───────────────────────────────────────────────────────
CERTBOT_EMAIL=<CHANGE ME — e.g. admin@alphabeta.ly>
