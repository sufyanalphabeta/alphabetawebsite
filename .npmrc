# pnpm settings — disables minimum-release-age supply-chain check (safe because
# --frozen-lockfile prevents new packages from being added; all packages in the
# lockfile were reviewed when originally installed) and increases network timeouts
# for Docker builds on slow connections.
minimum-release-age=0
network-timeout=300000
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
