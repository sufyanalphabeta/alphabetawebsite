{
  "kind": "collectionType",
  "collectionName": "clients",
  "info": {
    "singularName": "client",
    "pluralName": "clients",
    "displayName": "Client",
    "description": "Companies and organizations using AlphaBeta systems"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": {},
  "attributes": {
    "name_ar": { "type": "string", "required": true },
    "name_en": { "type": "string" },
    "slug": { "type": "uid", "targetField": "name_en", "required": true },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "industry": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::industry.industry"
    },
    "country_ar": { "type": "string" },
    "country_en": { "type": "string" },
    "description_ar": { "type": "text" },
    "description_en": { "type": "text" },
    "is_featured": { "type": "boolean", "default": false },
    "sort_order": { "type": "integer", "default": 0 },
    "software_products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::software-product.software-product",
      "inversedBy": "clients"
    }
  }
}
