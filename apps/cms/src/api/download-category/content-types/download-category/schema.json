{
  "kind": "collectionType",
  "collectionName": "download_categories",
  "info": {
    "singularName": "download-category",
    "pluralName": "download-categories",
    "displayName": "Download Category",
    "description": "Categories for the downloads center"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "name_ar": { "type": "string", "required": true },
    "name_en": { "type": "string" },
    "slug": { "type": "uid", "targetField": "name_en", "required": true },
    "sort_order": { "type": "integer", "default": 0 },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::download-item.download-item",
      "mappedBy": "category"
    }
  }
}
