      "allowedTypes": ["images"]
    },
    "website": { "type": "string" },
    "description_ar": { "type": "text" },
    "description_en": { "type": "text" },
    "partner_type": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::partner-type.partner-type",
