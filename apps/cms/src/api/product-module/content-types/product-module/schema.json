{
  "kind": "collectionType",
  "collectionName": "product_modules",
  "info": {
    "singularName": "product-module",
    "pluralName": "product-modules",
    "displayName": "Product Module",
    "description": "Modules within a software product"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "name_ar": { "type": "string", "required": true },
    "name_en": { "type": "string" },
    "description_ar": { "type": "text" },
    "description_en": { "type": "text" },
    "sort_order": { "type": "integer", "default": 0 },
    "is_core": { "type": "boolean", "default": true },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::software-product.software-product",
      "inversedBy": "modules"
    }
  }
}
