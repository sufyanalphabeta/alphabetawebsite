{
  "kind": "collectionType",
  "collectionName": "success_metrics",
  "info": {
    "singularName": "success-metric",
    "pluralName": "success-metrics",
    "displayName": "Success Metric",
    "description": "Measurable results within a success story"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "label_ar": { "type": "string", "required": true },
    "label_en": { "type": "string" },
    "value": { "type": "string", "required": true },
    "sort_order": { "type": "integer", "default": 0 },
    "story": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::success-story.success-story",
      "inversedBy": "metrics"
    }
  }
}
