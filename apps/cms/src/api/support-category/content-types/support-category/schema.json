{
  "kind": "collectionType",
  "collectionName": "support_categories",
  "info": {
    "singularName": "support-category",
    "pluralName": "support-categories",
    "displayName": "Support Category",
    "description": "Support center sections (installation guides, manuals, troubleshooting…)"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "name_ar": { "type": "string", "required": true },
    "name_en": { "type": "string" },
    "slug": { "type": "uid", "targetField": "name_en", "required": true },
    "description_ar": { "type": "text" },
    "description_en": { "type": "text" },
    "icon_name": { "type": "string" },
    "sort_order": { "type": "integer", "default": 0 },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::support-article.support-article",
      "mappedBy": "category"
    }
  }
}
